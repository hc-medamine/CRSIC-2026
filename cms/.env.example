# Local CMS — copy to .env.local and fill in. Never commit .env.local.
# URL-encode special characters in the password (e.g. # → %23).

DATABASE_URL=postgresql://crsic_cms_app:YOUR_PASSWORD@localhost:5432/crsic_db

# Idle session timeout (minutes) — locked in PRD
SESSION_TIMEOUT_MINUTES=30

# iron-session cookie encryption (min 32 characters)
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Public SPA origin for optional A1 preview tab (no trailing slash).
# Example: http://localhost:5500 — SPA must set PREVIEW_API_BASE to this CMS (e.g. http://localhost:3000).
# In development, if unset, the CMS falls back to http://localhost:5500.
# "Open public preview" always works in-CMS at /dashboard/preview/{token}.
PUBLIC_SITE_URL=

# Super Admin seed (npm run db:seed:super-admin) — local only
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_SUPER_ADMIN_DISPLAY_NAME=
SEED_SUPER_ADMIN_NAME_AR=
SEED_SUPER_ADMIN_NAME_EN=

# Test login bubbles (one-click on /login). NEVER set in production.
# Requires NODE_ENV !== production AND this flag = 1.
NEXT_PUBLIC_CMS_LOGIN_BUBBLES=
# SA / Reviewer passwords:
# CMS_LOGIN_BUBBLE_SA_PASSWORD=   # or SEED_SUPER_ADMIN_PASSWORD
# CMS_LOGIN_BUBBLE_REVIEWER_PASSWORD=
# Editors (shared password + numbered emails):
# CMS_LOGIN_BUBBLE_EDITOR_PASSWORD=
# EDITOR1_EMAIL=a.djefal@crsic.dz
# EDITOR2_EMAIL=t.medjelled@crsic.dz
# EDITOR3_EMAIL=i.megoussi@crsic.dz
# EDITOR4_EMAIL=a.derrafa@crsic.dz
