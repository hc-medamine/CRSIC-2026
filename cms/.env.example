# Local CMS — copy to .env.local and fill in. Never commit .env.local.
# URL-encode special characters in the password (e.g. # → %23).

DATABASE_URL=postgresql://crsic_cms_app:YOUR_PASSWORD@localhost:5432/crsic_db

# Idle session timeout (minutes) — locked in PRD
SESSION_TIMEOUT_MINUTES=30

# iron-session cookie encryption (min 32 characters)
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Public SPA origin for A1 preview links opened from the CMS (no trailing slash).
# Example: http://localhost:5500 or https://www.example.dz
PUBLIC_SITE_URL=

# Super Admin seed (npm run db:seed:super-admin) — local only
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_SUPER_ADMIN_DISPLAY_NAME=
SEED_SUPER_ADMIN_NAME_AR=
SEED_SUPER_ADMIN_NAME_EN=
